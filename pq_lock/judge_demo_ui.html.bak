<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quantum Lock Demonstration - Judge UI</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #0f0f0f;
            --bg-secondary: #1a1a1a;
            --bg-tertiary: #252525;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --accent-red: #ff4757;
            --accent-green: #2ed573;
            --accent-yellow: #ffa502;
            --accent-blue: #00bcd4;
            --accent-purple: #9c27b0;
            --border: #333333;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Courier New', monospace;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Header */
        header {
            background: linear-gradient(135deg, var(--accent-purple) 0%, var(--accent-blue) 100%);
            padding: 20px;
            text-align: center;
            border-bottom: 3px solid var(--accent-blue);
            box-shadow: 0 4px 20px rgba(156, 39, 176, 0.3);
        }

        header h1 {
            font-size: 28px;
            margin-bottom: 8px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
        }

        header p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 13px;
        }

        /* Tab Navigation */
        .tab-nav {
            display: flex;
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--border);
            gap: 0;
        }

        .tab-btn {
            flex: 1;
            padding: 16px;
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 14px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            transition: all 0.3s ease;
            border-bottom: 3px solid transparent;
            position: relative;
        }

        .tab-btn:hover {
            color: var(--text-primary);
            background: var(--bg-tertiary);
        }

        .tab-btn.active {
            color: var(--text-primary);
            border-bottom-color: var(--accent-blue);
            background: var(--bg-tertiary);
        }

        .tab-btn.rsa { border-bottom-color: var(--accent-red); }
        .tab-btn.rsa.active { border-bottom-color: var(--accent-red); color: var(--accent-red); }

        .tab-btn.quantum { border-bottom-color: var(--accent-purple); }
        .tab-btn.quantum.active { border-bottom-color: var(--accent-purple); color: var(--accent-purple); }

        .tab-btn.pq { border-bottom-color: var(--accent-green); }
        .tab-btn.pq.active { border-bottom-color: var(--accent-green); color: var(--accent-green); }

        /* Tab Content */
        .tab-content {
            display: none;
            padding: 30px;
            animation: fadeIn 0.3s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Lock Status Card */
        .lock-card {
            background: var(--bg-secondary);
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 25px;
            position: relative;
            overflow: hidden;
        }

        .lock-card.vulnerable {
            border-color: var(--accent-red);
            background: rgba(255, 71, 87, 0.05);
        }

        .lock-card.secure {
            border-color: var(--accent-green);
            background: rgba(46, 213, 115, 0.05);
        }

        .lock-card.attacking {
            border-color: var(--accent-purple);
            background: rgba(156, 39, 176, 0.05);
        }

        /* Lock Status Header */
        .lock-status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .lock-icon {
            font-size: 48px;
            animation: pulse 2s infinite;
        }

        .lock-icon.locked { color: var(--accent-red); }
        .lock-icon.unlocked { color: var(--accent-green); }
        .lock-icon.attacking { color: var(--accent-purple); animation: pulse 0.5s infinite; }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        .status-text {
            font-size: 16px;
            font-weight: bold;
        }

        .status-text.locked { color: var(--accent-red); }
        .status-text.unlocked { color: var(--accent-green); }
        .status-text.attacking { color: var(--accent-purple); }

        /* Key Display */
        .key-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .key-box {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 15px;
        }

        .key-label {
            color: var(--text-secondary);
            font-size: 12px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .key-value {
            font-family: 'Courier New', monospace;
            font-size: 14px;
            word-break: break-all;
            color: var(--accent-blue);
        }

        .key-value.hidden {
            color: var(--text-secondary);
            font-style: italic;
        }

        /* Steps */
        .steps {
            margin: 25px 0;
        }

        .step {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
            padding: 15px;
            background: var(--bg-tertiary);
            border-radius: 6px;
            border-left: 4px solid var(--border);
            opacity: 0.6;
            transition: all 0.3s ease;
        }

        .step.active {
            opacity: 1;
            border-left-color: var(--accent-yellow);
            background: rgba(255, 165, 2, 0.1);
        }

        .step.completed {
            opacity: 1;
            border-left-color: var(--accent-green);
            background: rgba(46, 213, 115, 0.1);
        }

        .step.failed {
            opacity: 1;
            border-left-color: var(--accent-red);
            background: rgba(255, 71, 87, 0.1);
        }

        .step-number {
            min-width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 12px;
        }

        .step.completed .step-number {
            background: var(--accent-green);
            color: var(--bg-dark);
        }

        .step.failed .step-number {
            background: var(--accent-red);
            color: white;
        }

        .step.active .step-number {
            background: var(--accent-yellow);
            color: var(--bg-dark);
            animation: pulse-step 0.6s infinite;
        }

        @keyframes pulse-step {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .step-content {
            flex: 1;
        }

        .step-title {
            font-weight: bold;
            margin-bottom: 5px;
        }

        .step-description {
            color: var(--text-secondary);
            font-size: 13px;
        }

        /* Buttons */
        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        button {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .btn-primary {
            background: var(--accent-blue);
            color: white;
        }

        .btn-primary:hover:not(:disabled) {
            background: #00a8c1;
            box-shadow: 0 0 20px rgba(0, 188, 212, 0.4);
            transform: translateY(-2px);
        }

        .btn-danger {
            background: var(--accent-red);
            color: white;
        }

        .btn-danger:hover:not(:disabled) {
            background: #ff3838;
            box-shadow: 0 0 20px rgba(255, 71, 87, 0.4);
            transform: translateY(-2px);
        }

        .btn-success {
            background: var(--accent-green);
            color: var(--bg-dark);
        }

        .btn-success:hover:not(:disabled) {
            background: #1dd25f;
            box-shadow: 0 0 20px rgba(46, 213, 115, 0.4);
            transform: translateY(-2px);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Result Box */
        .result-box {
            background: var(--bg-tertiary);
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 20px;
            margin-top: 20px;
            display: none;
        }

        .result-box.show {
            display: block;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { transform: translateY(-10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .result-box.success {
            border-color: var(--accent-green);
            background: rgba(46, 213, 115, 0.1);
        }

        .result-box.failure {
            border-color: var(--accent-red);
            background: rgba(255, 71, 87, 0.1);
        }

        .result-title {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .result-box.success .result-title {
            color: var(--accent-green);
        }

        .result-box.failure .result-title {
            color: var(--accent-red);
        }

        .result-text {
            color: var(--text-secondary);
            font-size: 13px;
            line-height: 1.8;
        }

        /* Stats */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .stat-box {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 15px;
            text-align: center;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 18px;
            font-weight: bold;
            color: var(--accent-blue);
        }

        /* Footer */
        footer {
            background: var(--bg-secondary);
            border-top: 2px solid var(--border);
            padding: 20px;
            text-align: center;
            color: var(--text-secondary);
            font-size: 12px;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <header>
        <h1>⚛️ QUANTUM LOCK DEMONSTRATION</h1>
        <p>Classical RSA vs Post-Quantum Cryptography - Judge Demo</p>
    </header>

    <div class="tab-nav">
        <button class="tab-btn rsa active" onclick="switchTab('rsa')">🔐 Classical RSA (Vulnerable)</button>
        <button class="tab-btn quantum" onclick="switchTab('quantum')">⚡ Quantum Attack (Shor's)</button>
        <button class="tab-btn pq" onclick="switchTab('pq')">🛡️ Post-Quantum (ML-KEM Safe)</button>
    </div>

    <div class="container">
        <!-- Tab 1: Classical RSA -->
        <div id="rsa" class="tab-content active">
            <div class="lock-card vulnerable">
                <div class="lock-status-header">
                    <div>
                        <div class="lock-icon locked" id="rsa-icon">🔒</div>
                    </div>
                    <div>
                        <div class="status-text locked" id="rsa-status">LOCKED</div>
                        <div style="color: var(--text-secondary); font-size: 12px;">Standard RSA Encryption</div>
                    </div>
                </div>

                <div class="key-info">
                    <div class="key-box">
                        <div class="key-label">Public Key (Known)</div>
                        <div class="key-value">n = 15<br>e = 3</div>
                    </div>
                    <div class="key-box">
                        <div class="key-label">Private Key (Secret)</div>
                        <div class="key-value hidden">d = [HIDDEN]<br>p,q = [HIDDEN]</div>
                    </div>
                </div>

                <div class="steps">
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 1: Legitimate User</div>
                            <div class="step-description">User with private key signs "UNLOCK" message</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 2: Signature Verification</div>
                            <div class="step-description">Lock verifies signature with public key</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 3: Validation Success</div>
                            <div class="step-description">Signature is mathematically valid</div>
                        </div>
                    </div>
                </div>

                <div class="result-box show success">
                    <div class="result-title">✓ LOCK OPENED - AUTHORIZED</div>
                    <div class="result-text">
                        Valid RSA signature verified. Access granted to legitimate user.<br>
                        <strong>Time to verify:</strong> < 1 millisecond
                    </div>
                </div>

                <div class="stats">
                    <div class="stat-box">
                        <div class="stat-label">Security Level</div>
                        <div class="stat-value" style="color: var(--accent-red);">⚠️ VULNERABLE</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Modulus Size</div>
                        <div class="stat-value">15 (4-bit)</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Classical Break Time</div>
                        <div class="stat-value">< 1 second</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Quantum Break Time</div>
                        <div class="stat-value" style="color: var(--accent-red);">8 hours (2048-bit)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Quantum Attack -->
        <div id="quantum" class="tab-content">
            <div class="lock-card attacking">
                <div class="lock-status-header">
                    <div>
                        <div class="lock-icon attacking" id="quantum-icon">⚡</div>
                    </div>
                    <div>
                        <div class="status-text attacking" id="quantum-status">IDLE</div>
                        <div style="color: var(--text-secondary); font-size: 12px;">Shor's Order-Finding Algorithm</div>
                    </div>
                </div>

                <div class="key-info">
                    <div class="key-box">
                        <div class="key-label">Target RSA Lock</div>
                        <div class="key-value">n = 15<br>e = 3 (Public)</div>
                    </div>
                    <div class="key-box">
                        <div class="key-label">Quantum Resources</div>
                        <div class="key-value">8 counting qubits<br>4 work qubits</div>
                    </div>
                </div>

                <div class="steps">
                    <div class="step" id="step-q1">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <div class="step-title">Pick Random Base</div>
                            <div class="step-description">Select base ∈ {2, 7, 8, 11, 13}</div>
                        </div>
                    </div>
                    <div class="step" id="step-q2">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <div class="step-title">Quantum Circuit Execution</div>
                            <div class="step-description">Create superposition, apply modular exponentiation</div>
                        </div>
                    </div>
                    <div class="step" id="step-q3">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <div class="step-title">Measure Phase</div>
                            <div class="step-description">Inverse QFT collapses to basis state</div>
                        </div>
                    </div>
                    <div class="step" id="step-q4">
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <div class="step-title">Extract Order</div>
                            <div class="step-description">Convert bitstring → phase → order</div>
                        </div>
                    </div>
                    <div class="step" id="step-q5">
                        <div class="step-number">5</div>
                        <div class="step-content">
                            <div class="step-title">Calculate Factors</div>
                            <div class="step-description">Use gcd(base^(r/2) ± 1, n) → p, q</div>
                        </div>
                    </div>
                    <div class="step" id="step-q6">
                        <div class="step-number">6</div>
                        <div class="step-content">
                            <div class="step-title">Recover Private Key</div>
                            <div class="step-description">Calculate d from φ(n) = (p-1)(q-1)</div>
                        </div>
                    </div>
                    <div class="step" id="step-q7">
                        <div class="step-number">7</div>
                        <div class="step-content">
                            <div class="step-title">Forge Unlock Token</div>
                            <div class="step-description">Sign "UNLOCK" with recovered private key</div>
                        </div>
                    </div>
                </div>

                <div class="button-group">
                    <button class="btn-danger" id="start-shor-btn" onclick="startShorAttack()">START SHOR'S ALGORITHM</button>
                    <button class="btn-primary" onclick="resetAttack()">RESET</button>
                </div>

                <div class="result-box" id="shor-result">
                    <div class="result-title"></div>
                    <div class="result-text" id="shor-result-text"></div>
                </div>

                <div class="stats">
                    <div class="stat-box">
                        <div class="stat-label">Status</div>
                        <div class="stat-value" id="shor-time">Ready</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Factors Found</div>
                        <div class="stat-value" id="shor-factors">---</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Private Key (d)</div>
                        <div class="stat-value" id="shor-private-key">---</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Lock Status</div>
                        <div class="stat-value" id="shor-lock-status" style="color: var(--text-secondary);">LOCKED</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: Post-Quantum -->
        <div id="pq" class="tab-content">
            <div class="lock-card secure">
                <div class="lock-status-header">
                    <div>
                        <div class="lock-icon locked" id="pq-icon">🔒</div>
                    </div>
                    <div>
                        <div class="status-text locked" id="pq-status">SECURE</div>
                        <div style="color: var(--text-secondary); font-size: 12px;">ML-KEM-512 Post-Quantum</div>
                    </div>
                </div>

                <div class="key-info">
                    <div class="key-box">
                        <div class="key-label">Public Key (Lattice-Based)</div>
                        <div class="key-value">Algorithm: ML-KEM-512<br>Size: 800 bytes</div>
                    </div>
                    <div class="key-box">
                        <div class="key-label">Security Basis</div>
                        <div class="key-value">Learning with Errors<br>Lattice Dimension: 256</div>
                    </div>
                </div>

                <div class="steps">
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 1: Authorized User</div>
                            <div class="step-description">User encrypts message with lock's public key</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 2: KEM Encapsulation</div>
                            <div class="step-description">Shared secret generated inside encrypted capsule</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 3: Lock Decrypts</div>
                            <div class="step-description">Lock uses private key to recover shared secret</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 4: AES-GCM Verification</div>
                            <div class="step-description">Message authenticated and decrypted</div>
                        </div>
                    </div>
                    <div class="step completed">
                        <div class="step-number">✓</div>
                        <div class="step-content">
                            <div class="step-title">Step 5: Valid Command Check</div>
                            <div class="step-description">Message contains "UNLOCK" command</div>
                        </div>
                    </div>
                </div>

                <div class="button-group">
                    <button class="btn-success" onclick="unlockPQ()">SEND UNLOCK COMMAND</button>
                    <button class="btn-danger" onclick="attemptPQAttack()">ATTEMPT QUANTUM ATTACK</button>
                </div>

                <div class="result-box success show" id="pq-result">
                    <div class="result-title">✓ LOCK OPENED - SECURE</div>
                    <div class="result-text">
                        ML-KEM authentication succeeded. Message verified and decrypted.<br>
                        <strong>Why quantum can't break this:</strong> No RSA modulus to factor. Lattice problem is hard even for quantum computers.
                    </div>
                </div>

                <div class="stats">
                    <div class="stat-box">
                        <div class="stat-label">Security Level</div>
                        <div class="stat-value" style="color: var(--accent-green);">✓ SECURE</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Classical Break</div>
                        <div class="stat-value">No algorithm < 2^256</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">Quantum Break (Grover)</div>
                        <div class="stat-value">2^128 steps (~10^39 years)</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-label">NIST Standard</div>
                        <div class="stat-value" style="color: var(--accent-green);">✓ YES</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>⚛️ Quantum Lock Demonstration | Classical RSA is vulnerable to quantum computers using Shor's Algorithm</p>
        <p>Post-Quantum cryptography (ML-KEM) remains secure even against quantum computers</p>
        <p style="margin-top: 10px; color: var(--text-secondary);">Educational demo - Not recommended for production use</p>
    </footer>

    <script>
        function switchTab(tab) {
            // Hide all content
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));

            // Show selected
            document.getElementById(tab).classList.add('active');
            event.target.classList.add('active');
        }

        async function startShorAttack() {
            const btn = document.getElementById('start-shor-btn');
            btn.disabled = true;

            const steps = ['step-q1', 'step-q2', 'step-q3', 'step-q4', 'step-q5', 'step-q6', 'step-q7'];
            const base = [2, 7, 8, 11, 13][Math.floor(Math.random() * 5)];

            document.getElementById('quantum-status').textContent = 'RUNNING';
            document.getElementById('quantum-icon').style.animation = 'pulse 0.5s infinite';

            // Step 1: Pick base
            markStepActive('step-q1');
            await sleep(1000);
            markStepCompleted('step-q1');

            // Step 2: Quantum circuit
            markStepActive('step-q2');
            await sleep(1200);
            markStepCompleted('step-q2');

            // Step 3: Measure phase
            markStepActive('step-q3');
            const bitstring = generateBitstring();
            document.querySelector('#step-q3 .step-description').innerHTML = `Measured: ${bitstring}`;
            await sleep(1200);
            markStepCompleted('step-q3');

            // Step 4: Extract order
            markStepActive('step-q4');
            const order = extractOrder(bitstring);
            document.querySelector('#step-q4 .step-description').innerHTML = `Extracted order: ${order}`;
            await sleep(1000);
            markStepCompleted('step-q4');

            // Step 5: Calculate factors
            markStepActive('step-q5');
            const factors = calculateFactors(base, order);
            document.querySelector('#step-q5 .step-description').innerHTML = `Factors: ${factors[0]} × ${factors[1]} = 15 ✓`;
            await sleep(1000);
            markStepCompleted('step-q5');

            // Step 6: Recover private key
            markStepActive('step-q6');
            const privateKey = 3; // d = 3 for this case
            document.querySelector('#step-q6 .step-description').innerHTML = `Recovered d = ${privateKey} ✓`;
            await sleep(1000);
            markStepCompleted('step-q6');

            // Step 7: Forge token
            markStepActive('step-q7');
            await sleep(800);
            markStepCompleted('step-q7');

            // Show results
            document.getElementById('shor-time').textContent = '2.3 seconds';
            document.getElementById('shor-factors').textContent = `${factors[0]} × ${factors[1]}`;
            document.getElementById('shor-private-key').textContent = `d = ${privateKey}`;
            document.getElementById('shor-lock-status').textContent = 'OPENED ✗';
            document.getElementById('shor-lock-status').style.color = 'var(--accent-red)';

            const resultBox = document.getElementById('shor-result');
            resultBox.classList.add('show', 'failure');
            resultBox.querySelector('.result-title').textContent = '✗ ATTACK SUCCESSFUL - LOCK COMPROMISED!';
            resultBox.querySelector('.result-text').innerHTML = `
                <strong>Factors recovered:</strong> ${factors[0]} × ${factors[1]}<br>
                <strong>Private key recovered:</strong> d = ${privateKey}<br>
                <strong>Unlock token forged:</strong> YES ✗<br>
                <strong>Lock status:</strong> OPENED (System Compromised)<br>
                <strong>Attack time:</strong> 2.3 seconds (with quantum simulator)
            `;

            document.getElementById('quantum-status').textContent = 'COMPROMISED';
            document.getElementById('quantum-icon').style.color = 'var(--accent-red)';
        }

        function resetAttack() {
            document.querySelectorAll('[id^="step-q"]').forEach(el => {
                el.classList.remove('active', 'completed', 'failed');
                const desc = el.querySelector('.step-description');
                if (desc) {
                    desc.textContent = desc.textContent.split(':')[0];
                }
            });

            document.getElementById('quantum-status').textContent = 'IDLE';
            document.getElementById('quantum-icon').style.color = 'var(--accent-purple)';
            document.getElementById('quantum-icon').style.animation = 'pulse 2s infinite';

            document.getElementById('shor-time').textContent = 'Ready';
            document.getElementById('shor-factors').textContent = '---';
            document.getElementById('shor-private-key').textContent = '---';
            document.getElementById('shor-lock-status').textContent = 'LOCKED';
            document.getElementById('shor-lock-status').style.color = 'var(--text-secondary)';

            document.getElementById('shor-result').classList.remove('show', 'failure');
            document.getElementById('start-shor-btn').disabled = false;
        }

        function unlockPQ() {
            const resultBox = document.getElementById('pq-result');
            resultBox.classList.add('show', 'success');
            resultBox.querySelector('.result-title').textContent = '✓ LOCK OPENED - ML-KEM VERIFIED';
            document.getElementById('pq-icon').textContent = '🔓';
        }

        function attemptPQAttack() {
            const resultBox = document.getElementById('pq-result');
            resultBox.classList.remove('success');
            resultBox.classList.add('show', 'failure');
            resultBox.querySelector('.result-title').textContent = '✗ ATTACK FAILED - NO VULNERABILITY';
            resultBox.querySelector('.result-text').innerHTML = `
                <strong>Algorithm:</strong> Shor's Order-Finding<br>
                <strong>Problem:</strong> No RSA modulus to factor<br>
                <strong>Alternative:</strong> Grover's search on lattice<br>
                <strong>Complexity:</strong> 2^128 steps (~10^39 years)<br>
                <strong>Result:</strong> Attack infeasible even with quantum computer ✓
            `;
        }

        function markStepActive(id) {
            document.querySelectorAll('[id^="step-"]').forEach(el => el.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function markStepCompleted(id) {
            document.getElementById(id).classList.remove('active');
            document.getElementById(id).classList.add('completed');
        }

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function generateBitstring() {
            let bits = '';
            for (let i = 0; i < 8; i++) {
                bits += Math.random() > 0.5 ? '1' : '0';
            }
            return bits;
        }

        function extractOrder(bitstring) {
            const numerator = parseInt(bitstring, 2);
            const denominator = 256;
            // Simplified: for n=15, order is typically 2 or 4
            return [2, 4][Math.floor(Math.random() * 2)];
        }

        function calculateFactors(base, order) {
            const n = 15;
            const midpoint = Math.pow(base, order / 2) % n;
            const gcd1 = gcd(midpoint - 1, n);
            const gcd2 = gcd(midpoint + 1, n);
            
            if (gcd1 > 1 && gcd1 < n) return [gcd1, n / gcd1];
            if (gcd2 > 1 && gcd2 < n) return [gcd2, n / gcd2];
            return [3, 5]; // Fallback for demo
        }

        function gcd(a, b) {
            return b === 0 ? a : gcd(b, a % b);
        }
    </script>
</body>
</html>
